Swapping numbers 
class Main {
    public static void main(String[] args) {
        int a=10;
        int b=20;
        int c;
        System.out.println("Initial value of a:"+a+" Initial value of b:"+b);
        System.out.println(" ");
        c=a;
        a=b;
        b=c;
        System.out.println("Swapped value of a:"+a+" Swapped value of b:"+b);

    }
}






